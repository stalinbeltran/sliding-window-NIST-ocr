{
  "nn": "dimensionador",
  "dataset": {
    "name": "mnist_full",
    "params": {
      "window_size": 14,
      "windows_per_image": 4
    }
  },
  "model": {
    "window_size": 14,
    "feature_dim": 32,
    "num_classes": 10,
    "channels": [
      16,
      32,
      64
    ]
  },
  "training": {
    "epochs": 5,
    "batch_size": 128,
    "lr": 0.001,
    "weight_decay": 0,
    "seed": 42,
    "val_fraction": 0.1,
    "log_every": 50
  }
}