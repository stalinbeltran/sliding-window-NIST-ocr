{
  "nn": "dimensionador",
  "dataset": {
    "name": "mnist_full",
    "params": {
      "window_size": 5,
      "windows_per_image": 30,
      "sampling": "raster",
      "stride": 5,
      "empty_fraction": 0.1,
      "stroke_width": 1
    }
  },
  "model": {
    "window_size": 5,
    "feature_dim": 32,
    "num_classes": 11,
    "channels": [
      16,
      32
    ]
  },
  "training": {
    "epochs": 5,
    "batch_size": 128,
    "lr": 0.001,
    "weight_decay": 0,
    "seed": 42,
    "val_fraction": 0.1,
    "log_every": 50
  }
}